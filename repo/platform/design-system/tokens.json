{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "version": "1.0.0",
  "metadata": {
    "name": "OneLink Design Tokens",
    "description": "Design system tokens for OneLink App/Web. Phase 2 baseline."
  },
  "color": {
    "brand": {
      "primary": { "$value": "#4F46E5", "$type": "color", "description": "Indigo-600 — primary brand" },
      "primary-hover": { "$value": "#4338CA", "$type": "color" },
      "primary-light": { "$value": "#EEF2FF", "$type": "color", "description": "Indigo-50 — light background" },
      "secondary": { "$value": "#7C3AED", "$type": "color", "description": "Violet-600 — secondary accent" }
    },
    "neutral": {
      "bg": { "$value": "#FFFFFF", "$type": "color" },
      "bg-secondary": { "$value": "#F9FAFB", "$type": "color", "description": "Gray-50" },
      "surface": { "$value": "#F3F4F6", "$type": "color", "description": "Gray-100" },
      "border": { "$value": "#E5E7EB", "$type": "color", "description": "Gray-200" },
      "border-focus": { "$value": "#6366F1", "$type": "color", "description": "Indigo-500" },
      "text-primary": { "$value": "#111827", "$type": "color", "description": "Gray-900" },
      "text-secondary": { "$value": "#6B7280", "$type": "color", "description": "Gray-500" },
      "text-placeholder": { "$value": "#9CA3AF", "$type": "color", "description": "Gray-400" }
    },
    "semantic": {
      "success": { "$value": "#059669", "$type": "color", "description": "Emerald-600" },
      "success-bg": { "$value": "#ECFDF5", "$type": "color" },
      "warning": { "$value": "#D97706", "$type": "color", "description": "Amber-600" },
      "warning-bg": { "$value": "#FFFBEB", "$type": "color" },
      "error": { "$value": "#DC2626", "$type": "color", "description": "Red-600" },
      "error-bg": { "$value": "#FEF2F2", "$type": "color" },
      "info": { "$value": "#2563EB", "$type": "color", "description": "Blue-600" },
      "info-bg": { "$value": "#EFF6FF", "$type": "color" }
    },
    "chat": {
      "user-bubble": { "$value": "#4F46E5", "$type": "color", "description": "Brand primary for user messages" },
      "user-bubble-text": { "$value": "#FFFFFF", "$type": "color" },
      "ai-bubble": { "$value": "#F3F4F6", "$type": "color", "description": "Gray-100 for AI messages" },
      "ai-bubble-text": { "$value": "#111827", "$type": "color" }
    }
  },
  "spacing": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "32px", "$type": "dimension" },
    "3xl": { "$value": "48px", "$type": "dimension" }
  },
  "typography": {
    "font-family": {
      "base": { "$value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
    },
    "font-size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "20px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "3xl": { "$value": "30px", "$type": "dimension" }
    },
    "font-weight": {
      "normal": { "$value": "400", "$type": "number" },
      "medium": { "$value": "500", "$type": "number" },
      "semibold": { "$value": "600", "$type": "number" },
      "bold": { "$value": "700", "$type": "number" }
    },
    "line-height": {
      "tight": { "$value": "1.25", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.75", "$type": "number" }
    }
  },
  "radius": {
    "sm": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "description": "Pill / circle" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)", "$type": "shadow" }
  },
  "breakpoint": {
    "sm": { "$value": "640px", "$type": "dimension" },
    "md": { "$value": "768px", "$type": "dimension" },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" }
  },
  "z-index": {
    "dropdown": { "$value": "1000", "$type": "number" },
    "sticky": { "$value": "1100", "$type": "number" },
    "modal-backdrop": { "$value": "1200", "$type": "number" },
    "modal": { "$value": "1300", "$type": "number" },
    "toast": { "$value": "1400", "$type": "number" }
  }
}
