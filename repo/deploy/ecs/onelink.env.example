ONELINK_ENV=production
RUST_LOG=info

# Replace with a real 32+ char value before production deploy.
INTERNAL_SHARED_SECRET=change-me-to-a-real-production-secret-with-32-plus-chars

# Replace password and DB endpoint before production deploy.
DATABASE_URL=postgres://onelink:change-me@127.0.0.1:5544/onelink

# Public entry and browser policy.
CORS_ALLOWED_ORIGINS=https://onelink.cool

# Internal service mesh on the shared ECS host.
IDENTITY_SERVICE_BASE_URL=http://127.0.0.1:18101
PROFILE_SERVICE_BASE_URL=http://127.0.0.1:18102
AI_CHAT_SERVICE_BASE_URL=http://127.0.0.1:18105
QUESTION_SERVICE_BASE_URL=http://127.0.0.1:18106
MATCH_SERVICE_BASE_URL=http://127.0.0.1:18107
SAFETY_SERVICE_BASE_URL=http://127.0.0.1:18108
DM_SERVICE_BASE_URL=http://127.0.0.1:18109
ADMIN_SERVICE_BASE_URL=http://127.0.0.1:18121
BFF_BASE_URL=http://127.0.0.1:18113

# App-server / BFF defaults.
APP_PORT=18121
BFF_DEFAULT_LOCALE=zh-CN
BFF_DEFAULT_REGION=CN
BFF_SUPPORTED_LOCALES=zh-CN,en-US,ja-JP,ko-KR,zh-TW
BFF_SUPPORTED_REGIONS=CN,US,JP,KR,TW
BFF_SUPPORTED_TIMEZONES=Asia/Shanghai,America/New_York,America/Los_Angeles,Asia/Tokyo,Asia/Seoul,Asia/Taipei,Europe/London,Europe/Berlin
BFF_TRANSLATIONS_SOURCE=env_inline

# Optional: replace inline sample with real managed translations if needed.
BFF_TRANSLATIONS_INLINE={"zh-CN":{"app.title":"OneLink","btn.submit":"提交","btn.cancel":"取消","msg.welcome":"欢迎"},"en-US":{"app.title":"OneLink","btn.submit":"Submit","btn.cancel":"Cancel","msg.welcome":"Welcome"}}
