{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "question.answered.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "event_version",
    "occurred_at",
    "producer",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_name": {
      "type": "string",
      "const": "question.answered.v1"
    },
    "event_version": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "const": "question-service"
    },
    "trace_id": {
      "type": "string",
      "format": "uuid"
    },
    "actor_user_id": {
      "type": "string",
      "format": "uuid"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "properties": {
        "answer_id": {
          "type": "string",
          "format": "uuid"
        },
        "delivery_id": {
          "type": "string",
          "format": "uuid"
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        },
        "variant_id": {
          "type": "string",
          "format": "uuid"
        },
        "answer_state": {
          "type": "string"
        },
        "question_text": {
          "type": "string",
          "description": "Phase C: stem text for context memory extraction (additive, optional in strict validators)"
        },
        "answer_payload": {
          "description": "Phase C: structured answer body as produced by POST /questions/answers (additive)"
        },
        "answer_text": {
          "type": "string",
          "description": "Phase C: normalized free text for heuristic_extract; preferred when present (additive)"
        },
        "requirement_tier": {
          "type": "string",
          "description": "Phase C: starter_required | profile_required | optional (additive)"
        },
        "question_style": {
          "type": "string",
          "description": "Phase C: e.g. single_choice | open_text (additive)"
        }
      },
      "required": [
        "answer_id",
        "delivery_id",
        "user_id"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
